# ───────────────────────────────────────────
# Server
# ───────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ───────────────────────────────────────────
# Client (Vite — prefix VITE_ to expose)
# ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5001

# ───────────────────────────────────────────
# IBM watsonx.ai
# ───────────────────────────────────────────
# Where to find your values:
#   API Key     → https://cloud.ibm.com/iam/apikeys
#   Project ID  → watsonx.ai UI → Manage → General → Project ID
#   URL         → your regional endpoint (default below is Dallas / us-south)
#   Model ID    → ibm/granite-3-3-8b-instruct  (default — can be overridden)

WATSONX_API_KEY=your-ibm-cloud-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct
